# ── SPMS Environment Variables ──────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.

# Yahoo Finance — NO API KEY required!
# All stock data (Indian NSE/BSE + US) is fetched via Vite's dev-server proxy.
# See vite.config.js for proxy config → query1/query2.finance.yahoo.com

# Supabase (optional — app runs in demo mode without it)
# Create a free project at: https://app.supabase.com
# Copy Project URL and anon public key from Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
